{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Pipeline outcomes (per minute)",
        "view": "timeSeries",
        "stacked": false,
        "region": "${AWS_REGION}",
        "metrics": [
          ["EsmartGo", "PipelineSuccess", { "stat": "Sum", "period": 60, "label": "Success" }],
          ["EsmartGo", "PipelineFailure", { "stat": "Sum", "period": 60, "label": "Failure" }]
        ]
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Pipeline duration (ms, p50/p95)",
        "view": "timeSeries",
        "region": "${AWS_REGION}",
        "metrics": [
          ["EsmartGo", "PipelineDuration", "outcome", "success", { "stat": "p50", "label": "p50" }],
          ["...", { "stat": "p95", "label": "p95" }]
        ]
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Per-agent duration",
        "view": "timeSeries",
        "region": "${AWS_REGION}",
        "metrics": [
          ["EsmartGo", "AgentDuration", "agent", "research", { "stat": "Average" }],
          ["...", "writer", { "stat": "Average" }],
          ["...", "seo", { "stat": "Average" }],
          ["...", "editor", { "stat": "Average" }],
          ["...", "meta", { "stat": "Average" }]
        ]
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Cache hits (research agent)",
        "view": "singleValue",
        "region": "${AWS_REGION}",
        "metrics": [
          ["EsmartGo", "CacheHit", "agent", "research", { "stat": "Sum", "period": 300 }]
        ]
      }
    },
    {
      "type": "metric",
      "x": 18,
      "y": 6,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Agent failures",
        "view": "singleValue",
        "region": "${AWS_REGION}",
        "metrics": [
          ["EsmartGo", "AgentFailure", "agent", "research", { "stat": "Sum", "period": 3600, "label": "research" }],
          ["...", "writer", { "stat": "Sum", "period": 3600, "label": "writer" }],
          ["...", "editor", { "stat": "Sum", "period": 3600, "label": "editor" }],
          ["...", "meta", { "stat": "Sum", "period": 3600, "label": "meta" }]
        ]
      }
    }
  ]
}
